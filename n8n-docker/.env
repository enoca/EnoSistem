# ===========================================
# enoca™ n8n Environment Configuration
# ===========================================

# Application
NODE_ENV=production
GENERIC_TIMEZONE=Europe/Istanbul

# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Scaling Configuration
EXECUTIONS_MODE=regular
EXECUTIONS_TIMEOUT=3600
N8N_WORKER_ENABLED=false

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password_change_me

# Redis Queue
REDIS_HOST=redis
REDIS_PORT=6379

# AI/LLM Configuration
AI_GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# enoca™ API Endpoints
# ===========================================

# KEP API
KEP_API_URL=https://kep-api.enoca.com/v1
KEP_API_KEY=your_kep_api_key_here

# Connector API
CONNECTOR_API_URL=https://connector-api.enoca.com/v1
CONNECTOR_API_KEY=your_connector_api_key_here

# EnoPrice API
ENOPRICE_API_URL=https://enoprice-api.enoca.com/api/v1
ENOPRICE_CLIENT_ID=your_enoprice_client_id
ENOPRICE_CLIENT_SECRET=your_enoprice_client_secret

# EnoRep API
ENOREP_API_URL=https://enorep-api.enoca.com/v1
ENOREP_API_KEY=your_enorep_api_key_here

# EnoCart MQTT
ENOCART_MQTT_BROKER=mqtt://enocart-mqtt.enoca.com:1883
ENOCART_MQTT_CLIENT_ID=n8n_enocart

# ===========================================
# External Platform APIs
# ===========================================

# Trendyol
TRENDYOL_API_URL=https://api.trendyol.com
TRENDYOL_SUPPLIER_ID=your_supplier_id
TRENDYOL_API_KEY=your_trendyol_api_key

# Hepsiburada
HEPSIBURADA_API_URL=https://api.hepsiburada.com
HEPSIBURADA_MERCHANT_ID=your_merchant_id
HEPSIBURADA_API_KEY=your_hepsiburada_api_key

# Amazon
AMAZON_SP_API_URL=https://sellingpartnerapi.amazon.com
AMAZON_CLIENT_ID=your_amazon_client_id
AMAZON_CLIENT_SECRET=your_amazon_client_secret

# ===========================================
# Notification Channels
# ===========================================

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@enoca.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=n8n@enoca.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#n8n-alerts

# ===========================================
# Monitoring (Optional)
# ===========================================

GRAFANA_PASSWORD=admin_change_me
PROMETHEUS_RETENTION=30d
